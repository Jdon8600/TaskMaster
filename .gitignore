# See https://help.github.com/articles/ignoring-files for more about ignoring files.
#
# Temporary files generated by your text editor or operating system
# belong in git's global ignore instead:
# `$XDG_CONFIG_HOME/git/ignore` or `~/.config/git/ignore`

# System files
.DS_Store
Thumbs.db

# IDEs and editors
.idea/
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace

# Visual Studio Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
!.vscode/mcp.json
.history/*
.github/workflows/*
.github/dependabot.yml


# ============
# Backend (Rails)
# ============

# Ignore bundler config.
taskmaster-backend/.bundle

# Ignore all environment files.
taskmaster-backend/.env*

# Ignore all logfiles and tempfiles.
taskmaster-backend/log/*
taskmaster-backend/tmp/*
!taskmaster-backend/log/.keep
!taskmaster-backend/tmp/.keep

# Ignore pidfiles, but keep the directory.
taskmaster-backend/tmp/pids/*
!taskmaster-backend/tmp/pids/
!taskmaster-backend/tmp/pids/.keep

# Ignore storage (uploaded files in development and any SQLite databases).
taskmaster-backend/storage/*
!taskmaster-backend/storage/.keep
taskmaster-backend/tmp/storage/*
!taskmaster-backend/tmp/storage/
!taskmaster-backend/tmp/storage/.keep

taskmaster-backend/public/assets

# Ignore key files for decrypting credentials and more.
taskmaster-backend/config/*.key

# ============
# Frontend (Angular)
# ============

# Compiled output
taskmaster-frontend/dist
taskmaster-frontend/tmp
taskmaster-frontend/out-tsc
taskmaster-frontend/bazel-out

# Node
taskmaster-frontend/node_modules
taskmaster-frontend/npm-debug.log
taskmaster-frontend/yarn-error.log

# Miscellaneous
taskmaster-frontend/.angular/cache
taskmaster-frontend/.sass-cache/
taskmaster-frontend/connect.lock
taskmaster-frontend/coverage
taskmaster-frontend/libpeerconnection.log
taskmaster-frontend/testem.log
taskmaster-frontend/typings
taskmaster-frontend/__screenshots__/

